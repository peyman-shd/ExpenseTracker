@model ExpenseTracker.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h1>Dashboard</h1>

<div class="row">
    <div class="col-md-4">
        <div class="card p-3 mb-3">
            <h4>Total Income</h4>
            <p>$@Model.TotalIncome.ToString("N2")</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 mb-3">
            <h4>Total Expense</h4>
            <p>$@Model.TotalExpense.ToString("N2")</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 mb-3">
            <h4>Net Balance</h4>
            @if (Model.NetBalance >= 0)
            {
                <p class="text-success">$@Model.NetBalance.ToString("N2")</p>
            }
            else
            {
                <p class="text-danger">$@Model.NetBalance.ToString("N2")</p>
            }
        </div>
    </div>
</div>

<h3>Card Summary</h3>

<table class="table table-bordered">
    <thead>
    <tr>
        <th>Card Name</th>
        <th>Card Type</th>
        <th>Current Balance</th>
        <th>Current Debt</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var card in Model.CardSummaries)
    {
        <tr>
            <td>@card.CardName</td>
            <td>@card.CardType</td>
            <td>$@card.CurrentBalance.ToString("N2")</td>
            <td>
                @if (card.CardType == "Credit")
                {
                    @if (card.InstallmentPortion > 0)
                    {
                        <div class="text-danger" style="font-size: 1.1em; font-weight: 700;">
                            Regular: $@card.RegularDebt.ToString("N2")
                        </div>

                        <div style="font-size: 0.95em; font-weight: 600; margin-top: 4px;">
                            Total: $@card.CurrentDebt.ToString("N2")
                        </div>

                        <div class="text-warning" style="font-size: 0.85em; margin-top: 2px;">
                            Installment: $@card.InstallmentPortion.ToString("N2")
                        </div>
                    }
                    else
                    {
                        <div>
                            <strong>$@card.CurrentDebt.ToString("N2")</strong>
                        </div>
                    }
                }
                else
                {
                    @:-
                }
            </td>
        </tr>
    }
    </tbody>
</table>