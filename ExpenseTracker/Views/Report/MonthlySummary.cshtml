@model ExpenseTracker.Models.MonthlySummaryViewModel

@{
    ViewData["Title"] = "Monthly Summary";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Monthly Summary</h1>

    <a asp-action="Charts"
       asp-route-year="@Model.SelectedYear"
       asp-route-month="@Model.SelectedMonth"
       asp-route-cardId="@Model.SelectedCardId"
       class="btn btn-outline-success">
        📊 Charts
    </a>
</div>

<form asp-action="MonthlySummary" method="get" class="mb-4">
    <div class="row">
        <div class="col-md-3">
            <label class="form-label">Year</label>
            <input type="number" name="year" value="@Model.SelectedYear" class="form-control" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Month</label>
            <select name="month" class="form-control">
                @{
                    var months = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.MonthNames;
                }

                @for (int i = 1; i <= 12; i++)
                {
                    if (i == Model.SelectedMonth)
                    {
                        <option value="@i" selected>@months[i - 1]</option>
                    }
                    else
                    {
                        <option value="@i">@months[i - 1]</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">Card</label>
            <select name="cardId" class="form-control">
                <option value="">All Cards</option>

                @foreach (var card in Model.Cards)
                {
                    if (Model.SelectedCardId == card.CardId)
                    {
                        <option value="@card.CardId" selected>@card.CardName</option>
                    }
                    else
                    {
                        <option value="@card.CardId">@card.CardName</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-3 d-flex align-items-end">
            <button type="submit" class="btn btn-primary">Filter</button>
        </div>
        
    </div>
</form>

<div class="row">
    <div class="col-md-4">
        <div class="card p-3 mb-3">
            <h4>Total Income</h4>
            <p>$@Model.TotalIncome.ToString("N2")</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 mb-3">
            <h4>Total Expense</h4>
            <p>$@Model.TotalExpense.ToString("N2")</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 mb-3">
            <h4>Monthly Net Balance</h4>
            <p>$@Model.NetBalance.ToString("N2")</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 mb-3">
            <h4>Overall Balance</h4>
            <p>$@Model.OverallBalance.ToString("N2")</p>
        </div>
    </div>
</div>

<h3>Transactions</h3>

<table class="table table-bordered">
    <thead>
    <tr>
        <th>Title</th>
        <th>Amount</th>
        <th>Type</th>
        <th>Category</th>
        <th>Date</th>
        <th>Card</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var transaction in Model.Transactions)
    {
        <tr>
            <td>@transaction.Title</td>
            <td>$@transaction.Amount.ToString("N2")</td>
            <td>@transaction.TransactionType</td>
            <td>@transaction.Category</td>
            <td>@transaction.TransactionDate.ToString("yyyy-MM-dd")</td>
            <td>@transaction.Card?.CardName</td>
        </tr>
    }
    </tbody>
</table>

<h3>Installments</h3>

@if (Model.Installments != null && Model.Installments.Any())
{
    <table class="table table-bordered">
        <thead>
        <tr>
            <th>Title</th>
            <th>Card</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Remaining</th>
            <th>Action</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Installments)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.CardName</td>
                <td>$@item.Amount.ToString("N2")</td>
                <td>
                    @if (item.IsPaid)
                    {
                        <span class="text-success">Paid</span>
                    }
                    else
                    {
                        <span class="text-warning">Unpaid</span>
                    }
                </td>
                <td>
                    $@item.RemainingAmount.ToString("N2")
                </td>
                <td>
                    @if (!item.IsPaid)
                    {
                        <form asp-action="MarkInstallmentAsPaid" method="post">
                            <input type="hidden" name="installmentPaymentId" value="@item.InstallmentPaymentId" />
                            <button type="submit" class="btn btn-sm btn-success">Mark as Paid</button>
                        </form>
                    }
                    else
                    {
                        <span>-</span>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>No installments for this month.</p>
}