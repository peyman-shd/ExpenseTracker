@model ExpenseTracker.Models.Transaction

@{
    ViewData["Title"] = "Delete Transaction";
}

<div class="container mt-4">

    <!-- Header -->
    <div class="mb-4">
        <h2 class="fw-bold text-danger mb-0">Delete Transaction</h2>
        <small class="text-muted">Please review before deleting</small>
    </div>

    <!-- Card -->
    <div class="card shadow-sm border-danger">
        <div class="card-body">

            <!-- Warning -->
            <div class="alert alert-danger mb-4">
                <strong>Warning:</strong> Are you sure you want to delete this transaction?
            </div>

            <!-- Summary List -->
            <ul class="list-group list-group-flush mb-4">

                <li class="list-group-item d-flex justify-content-between">
                    <span class="fw-semibold">Title</span>
                    <span>@Model.Title</span>
                </li>

                <li class="list-group-item d-flex justify-content-between">
                    <span class="fw-semibold">Amount</span>
                    <span>$@Model.Amount.ToString("N2")</span>
                </li>

                <li class="list-group-item d-flex justify-content-between">
                    <span class="fw-semibold">Type</span>
                    <span>@Model.TransactionType</span>
                </li>

                <li class="list-group-item d-flex justify-content-between">
                    <span class="fw-semibold">Category</span>
                    <span>@Model.Category</span>
                </li>

                <li class="list-group-item d-flex justify-content-between">
                    <span class="fw-semibold">Date</span>
                    <span>@Model.TransactionDate.ToString("yyyy-MM-dd")</span>
                </li>

                <li class="list-group-item d-flex justify-content-between">
                    <span class="fw-semibold">Card</span>
                    <span>@Model.Card?.CardName</span>
                </li>

            </ul>

            <!-- Buttons -->
            <form asp-action="DeleteConfirmed" method="post">
                <input type="hidden" asp-for="TransactionId" />

                <button type="submit" class="btn btn-danger px-4">Delete</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </form>

        </div>
    </div>
</div>