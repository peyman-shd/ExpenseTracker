@model ExpenseTracker.Models.Transaction

<h1>Delete Transaction</h1>

<h3>Are you sure you want to delete this transaction?</h3>

<div>
    <p><strong>Title:</strong> @Model.Title</p>
    <p><strong>Amount:</strong> @Model.Amount</p>
    <p><strong>Type:</strong> @Model.TransactionType</p>
    <p><strong>Category:</strong> @Model.Category</p>
    <p><strong>Date:</strong> @Model.TransactionDate.ToString("yyyy-MM-dd")</p>
    <p><strong>Card:</strong> @Model.Card?.CardName</p>
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="TransactionId" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>