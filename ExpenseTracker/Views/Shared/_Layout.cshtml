@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.TagHelpers
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ExpenseTracker</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ExpenseTracker.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
<header>
    <nav class="navbar navbar-light bg-white border-bottom shadow-sm mb-3">
        <div class="container-fluid">

            <div class="d-flex align-items-center">
                <a class="navbar-brand fw-bold me-3" asp-area="" asp-controller="Home" asp-action="Index">
                    ExpenseTracker
                </a>

                <button class="btn border-0 fs-4" type="button" data-bs-toggle="collapse" data-bs-target="#mainMenu" aria-expanded="false" aria-controls="mainMenu">
                    ☰
                </button>
            </div>

            <ul class="navbar-nav ms-auto d-flex flex-row align-items-center">
                @if (SignInManager.IsSignedIn(User))
                {
                    <li class="nav-item me-2">
                        <span class="nav-link text-dark mb-0">Hello @User.Identity?.Name</span>
                    </li>
                    <li class="nav-item">
                        <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="mb-0">
                            <button type="submit" class="nav-link btn btn-link text-dark border-0 p-0">
                                Logout
                            </button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item me-3">
                        <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Register</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
                    </li>
                }
            </ul>
        </div>
    </nav>

    <div class="collapse" id="mainMenu">
        <div class="bg-white border-bottom shadow-sm">
            <div class="container-fluid py-2">
                <a class="d-block py-2 text-decoration-none text-dark" asp-controller="Home" asp-action="Index">Home</a>
                <a class="d-block py-2 text-decoration-none text-dark" asp-controller="Card" asp-action="Index">Cards</a>
                <a class="d-block py-2 text-decoration-none text-dark" asp-controller="Transaction" asp-action="Index">Transactions</a>
                <a class="d-block py-2 text-decoration-none text-dark" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a class="d-block py-2 text-decoration-none text-dark" asp-controller="Report" asp-action="MonthlySummary">Reports</a>
            </div>
        </div>
    </div>
</header>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - ExpenseTracker - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>