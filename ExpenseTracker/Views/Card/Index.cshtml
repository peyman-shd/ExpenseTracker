@model List<ExpenseTracker.Models.Card>

<h1>Cards</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add Card</a>
</p>

<table class="table table-bordered">
    <thead>
    <tr>
        <th>Card Name</th>
        <th>Limit</th>
        <th>Balance</th>
        <th>Type</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var card in Model)
    {
        <tr>
            <td>@card.CardName</td>
            <td>@card.Limit</td>
            <td>@card.CurrentBalance</td>
            <td>@card.CardType</td>
            <td>
                <a asp-action="Edit" asp-route-id="@card.CardId" class="btn btn-warning btn-sm">Edit</a>
                <a asp-action="Delete" asp-route-id="@card.CardId" class="btn btn-danger btn-sm">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>