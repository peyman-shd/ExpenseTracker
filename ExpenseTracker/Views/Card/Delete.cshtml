@model ExpenseTracker.Models.Card

<h1>Delete Card</h1>

<h3>Are you sure you want to delete this card?</h3>

<div>
    <p><strong>Card Name:</strong> @Model.CardName</p>
    <p><strong>Limit:</strong> @Model.Limit</p>
    <p><strong>Current Balance:</strong> @Model.CurrentBalance</p>
    <p><strong>Card Type:</strong> @Model.CardType</p>
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="CardId" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>